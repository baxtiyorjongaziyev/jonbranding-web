{
  "name": "jonbranding-portfolio-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node --esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auth": "ts-node --esm src/auth.ts",
    "workflow": "ts-node --esm src/workflow.ts",
    "workflow:once": "WORKFLOW_MODE=once ts-node --esm src/index.ts",
    "workflow:instagram": "WORKFLOW_MODE=instagram ts-node --esm src/index.ts",
    "workflow:telegram": "WORKFLOW_MODE=telegram ts-node --esm src/index.ts",
    "workflow:all": "WORKFLOW_MODE=all ts-node --esm src/index.ts"
  },
  "dependencies": {
    "@sanity/client": "^7.23.1",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.1",
    "googleapis": "^173.0.0",
    "telegram": "^2.26.0",
    "input": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}