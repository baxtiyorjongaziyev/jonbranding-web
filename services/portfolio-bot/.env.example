# Telegram API (my.telegram.org dan oling)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_SESSION=         # auth.ts ishlatgach avtomatik to'ldiriladi
TG_CHANNEL_IDS=-1001234567890,-1009876543210   # kuzatiladigan kanal/group IDlari (vergul bilan)
TG_NOTIFY_CHAT_ID=  # natijalar keriladigan chat ID (sizning shaxsiy ID)

# Oisha AI
OISHA_API_URL=https://oisha-master-bot-xxxx.run.app
OISHA_SECRET_KEY=your_secret_key

# Google Drive (Service Account JSON fayl yo'li)
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# Sanity CMS
SANITY_PROJECT_ID=h6ymmj0v
SANITY_DATASET=production
SANITY_TOKEN=        # sanity.io/manage → project → API → tokens → Write token
