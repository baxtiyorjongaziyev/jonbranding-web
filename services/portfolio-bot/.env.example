# =========================================
# Telegram Configuration
# =========================================
# my.telegram.org dan oling
TG_API_ID=30643078
TG_API_HASH=e5850001c1d86ac0fb439fbd8319cb7f
# oisha-os USERBOT_SESSION_STRING
TG_SESSION=
# Vergul bilan ajratilgan kanallar (@username yoki raqam)
TG_CHANNEL_IDS=@JonBranding
# Natijalar yuboriladigan chat ID
TG_NOTIFY_CHAT_ID=150074828

# =========================================
# Instagram Configuration
# =========================================
# Apify API Key (instagram scraper uchun)
# https://console.apify.com → API keys
# Agar yo'q bo'lsa, mock data ishlatiladi
APIFY_API_KEY=

# =========================================
# AI (Gemini) Configuration
# =========================================
# Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =========================================
# Google Drive Configuration
# =========================================
# Service Account JSON fayl yo'li (https://console.cloud.google.com)
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# Yoki oddiy API Key (faqat public folderlar uchun)
GOOGLE_API_KEY=

# =========================================
# Sanity CMS Configuration
# =========================================
SANITY_PROJECT_ID=h6ymmj0v
SANITY_DATASET=production
# sanity.io/manage → API → Tokens → Add API token (write access)
SANITY_TOKEN=

# =========================================
# Workflow Mode
# =========================================
# all       — Telegram + Instagram + Drive + Sanity (default)
# telegram  — faqat Telegram userbot
# instagram — faqat Instagram workflow
# once      — bir marta ishga tushirish va tugatish
WORKFLOW_MODE=all

# =========================================
# Portfolio Workflow Configuration
# =========================================
# Instagram dan kuzatiladigan akkauntlar (vergul bilan)
INSTAGRAM_ACCOUNTS=jonbranding

# Qidiriladigan hashtaglar (vergul bilan)
INSTAGRAM_HASHTAGS=#jonbranding,#brandinguz,#logodesignuz

# Har bir manbadan olinadigan postlar soni
POSTS_PER_SOURCE=10

# Faqat Drive linki bor postlarni yuklash?
REQUIRE_DRIVE_LINK=true

# Google Drive Direct Sync
# Agar bot bevosita Google Drive'ni tekshirishini xohlasangiz, Parent Folder ID yozing
DRIVE_PARENT_FOLDER_ID=

# Avtomatik Sanity'ga yuklash
AUTO_UPLOAD=true

# Tekshirish intervali (daqiqalarda)
INTERVAL_MINUTES=60